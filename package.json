{
  "name": "cloud-quran",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:expo": "cd apps/expo && bun start",
    "dev:desktop": "cd apps/desktop && bun run dev",
    "dev:api": "cd apps/api && bun run dev",
    "dev:website": "cd apps/marketing && bun run dev",
    "build:website": "cd apps/marketing && bun run build",
    "deploy:api": "cd apps/api && bun run deploy",
    "build:desktop": "bun run scripts/build-desktop.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p packages/quran-data/tsconfig.json && tsc --noEmit -p packages/shared/tsconfig.json && tsc --noEmit -p apps/expo/tsconfig.json && tsc --noEmit -p apps/api/tsconfig.json && tsc --noEmit -p apps/desktop/tsconfig.json && cd apps/marketing && npx astro check",
    "test": "NODE_OPTIONS='--experimental-vm-modules' bunx jest --projects packages/quran-data packages/shared apps/expo apps/api",
    "prepare-data": "bun run scripts/prepare-data.ts",
    "verify": "bun run scripts/verify-quran.ts",
    "prepare-audio": "bun run scripts/prepare-audio.ts"
  },
  "resolutions": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.800.0",
    "@biomejs/biome": "^2.4.7",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/bun": "^1.3.10",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.2.10",
    "fast-xml-parser": "^5.4.2",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "version": "1.0.0"
}
