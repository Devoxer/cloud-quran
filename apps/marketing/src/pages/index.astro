---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import DownloadButtons from '../components/DownloadButtons.astro';

const title = 'Cloud Quran — Read the Holy Quran Online';
const description = 'Read the Holy Quran online with accurate Uthmani script, English translation, and tafsir. Available on iOS, Android, Web, and Desktop.';
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <SEOHead title={title} description={description} canonicalUrl="https://cloudquran.app/" />
  </Fragment>
  <section class="hero">
    <h1>The Quran, Always With You</h1>
    <p class="subtitle">
      Read the Holy Quran with authentic Uthmani script, English translation, and tafsir.
      Completely free, private, and available on every platform.
    </p>
    <DownloadButtons layout="horizontal" />
  </section>

  <section class="features">
    <div class="feature">
      <h2>Authentic Text</h2>
      <p>
        KFGQPC Uthmani script verified with SHA-256 hashes per ayah.
        Every letter is exactly as it should be.
      </p>
    </div>
    <div class="feature">
      <h2>100% Private</h2>
      <p>
        Zero analytics. Zero tracking. Zero third-party SDKs.
        Your reading is between you and Allah.
      </p>
    </div>
    <div class="feature">
      <h2>Works Offline</h2>
      <p>
        The full Quran text is bundled locally.
        No internet connection needed to read.
      </p>
    </div>
    <div class="feature">
      <h2>Every Platform</h2>
      <p>
        iOS, Android, Web, macOS, Windows, and Linux.
        One app, everywhere you are.
      </p>
    </div>
    <div class="feature">
      <h2>Audio Recitation</h2>
      <p>
        Listen to renowned reciters with verse-by-verse highlighting.
        Background playback and offline downloads.
      </p>
    </div>
    <div class="feature">
      <h2>Cross-Device Sync</h2>
      <p>
        Sign in to sync your reading position, bookmarks, and preferences
        across all your devices.
      </p>
    </div>
  </section>

  <section class="cta">
    <h2>Start Reading Today</h2>
    <p>Choose your platform and begin your journey with the Quran.</p>
    <a href="/download" class="cta-button">Download Cloud Quran</a>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    padding: 3rem 0;
  }

  .feature {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .feature h2 {
    font-size: 1.15rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .feature p {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .cta {
    text-align: center;
    padding: 3rem 0 2rem;
  }

  .cta h2 {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .cta p {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }

  .cta-button {
    display: inline-block;
    background: var(--color-primary);
    color: white;
    padding: 0.75rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .cta-button:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .hero h1 {
      font-size: 1.75rem;
    }

    .subtitle {
      font-size: 1rem;
    }
  }
</style>
